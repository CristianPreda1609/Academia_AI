# Copy this file to .env and fill in your values:
#     cp .env.example .env        (PowerShell: copy .env.example .env)
#
# .env is gitignored - never commit real keys.
# Every line below is OPTIONAL except API_KEY: anything you leave out falls back
# to the default in config.py. A real environment variable overrides .env.

# --- Required ---------------------------------------------------------------
# Key for the chat model (Azure OpenAI by default).
API_KEY=

# --- Models (defaults shown) ------------------------------------------------
MODEL_NAME=gpt-5-mini
MODEL_ENDPOINT=https://ai-academy-foundry.openai.azure.com/openai/v1/chat/completions
EMBEDDINGS_MODEL=qwen3-embedding:latest
EMBEDDINGS_ENDPOINT=http://localhost:11434/api/embed

# --- Retrieval tuning -------------------------------------------------------
CHUNK_SIZE=100
CHUNK_OVERLAP=20
TOP_N=4
SIMILARITY_THRESHOLD=0.5
MAX_CONTEXT_TOKENS=16000

# --- Cost tracking (USD per million tokens) ---------------------------------
INPUT_TOKEN_PRICE_PER_MILLION=30
OUTPUT_TOKEN_PRICE_PER_MILLION=70

# --- Logging ----------------------------------------------------------------
# LOG_LEVEL=DEBUG shows retrieval details (similarity scores, discovered tools).
LOG_LEVEL=INFO
LOG_FILE=app.log
